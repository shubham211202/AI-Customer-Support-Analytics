{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Backend: FastAPI localhost",
      "type": "python",
      "request": "launch",
      "module": "uvicorn",
      "args": ["app.main:app", "--reload", "--host", "127.0.0.1", "--port", "8000"],
      "cwd": "${workspaceFolder}/backend",
      "env": {
        "DATABASE_URL": "sqlite:///./local.db"
      },
      "jinja": true,
      "justMyCode": true
    }
  ]
}
